{
  "workbench.externalBrowser": "chrome",
  "latex-workshop.view.autoFocus.enabled": true,
  "latex-workshop.latex.watch.pdf.delay": 250,
  "latex-workshop.view.outline.sync.viewer": true,
  "latex-workshop.latex.outDir": "%DIR%/out",
  "latex-workshop.latex.auxDir": "%DIR%/out",
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.autoBuild.run": "onFileChange",
  "latex-workshop.latex.autoBuild.interval": 1200,
  "latex-workshop.latex.build.enableMagicComments": true,
  "latex-workshop.latex.search.rootFiles.include": ["Bernal_H.tex"],
  "latex-workshop.latex.build.rootfileInStatus": true,
  "latex-workshop.view.pdf.viewer": "browser",
  "latex-workshop.view.pdf.tab.editorGroup": "current",
  "latex-workshop.view.pdf.reload.transition": "none",
  "latex-workshop.synctex.afterBuild.enabled": true,
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "/Users/zhumber/Library/TinyTeX/bin/universal-darwin/latexmk",
      "cwd": "%DIR%",
      "args": [
        "-cd",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ],
      "env": {
        "PATH": "/Users/zhumber/Library/TinyTeX/bin/universal-darwin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"
      }
    },
    {
      "name": "latexmk-force",
      "command": "/Users/zhumber/Library/TinyTeX/bin/universal-darwin/latexmk",
      "cwd": "%DIR%",
      "args": [
        "-cd",
        "-g",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ],
      "env": {
        "PATH": "/Users/zhumber/Library/TinyTeX/bin/universal-darwin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"
      }
    },
    {
      "name": "latexmk-clean",
      "command": "/Users/zhumber/Library/TinyTeX/bin/universal-darwin/latexmk",
      "cwd": "%DIR%",
      "args": ["-cd", "-c", "-outdir=%OUTDIR%", "%DOC%"],
      "env": {
        "PATH": "/Users/zhumber/Library/TinyTeX/bin/universal-darwin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"
      }
    }
  ],
  "latex-workshop.latex.recipes": [
    { "name": "latexmk (TinyTeX)", "tools": ["latexmk"] },
    { "name": "latexmk: forzar recompilación (-g)", "tools": ["latexmk-force"] },
    { "name": "latexmk: limpiar auxiliares (-c)", "tools": ["latexmk-clean"] }
  ]
}
